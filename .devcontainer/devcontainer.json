{
	"name": "SDTECH Bank Dev Container",
	"dockerComposeFile": "docker-compose.yml",
	"service": "app",
	"workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
	"mounts": [
		"source=${localEnv:HOME}/.ssh,target=/home/codespace/.ssh,type=bind,consistency=cached",
		"source=${localEnv:HOME}/.gitconfig,target=/home/codespace/.gitconfig,type=bind",
		"source=${localEnv:HOME}/.aspnet/https,target=/https,type=bind"
	],
	"features": {
		"ghcr.io/stuartleeks/dev-container-features/shell-history:0": {},
		"ghcr.io/nikiforovall/devcontainer-features/dotnet-csharpier:1": {}
	},
	"forwardPorts": [
		5000,
		5001,
		15672
	],
	"portsAttributes": {
		"5001": {
			"protocol": "https"
		},
		"15672": {
			"label": "RabbitMQ Management UI"
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-dotnettools.csharp",
				"ms-dotnettools.csdevkit",
				"nrwl.angular-console",
				"redhat.vscode-yaml",
				"openai.chatgpt",
				"esbenp.prettier-vscode",
				"ritwickdey.LiveServer",
				"SonarSource.sonarlint-vscode",
				"ritwickdey.LiveServer",
				"vscode-icons-team.vscode-icons",
				"ms-python.black-formatter"
			]
		}
	}
}
